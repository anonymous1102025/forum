# ── Scheduler ─────────────────────────────────────────────────────────────────
FETCH_HOUR_UTC=6
FETCH_ON_STARTUP=true

# ── CORS ──────────────────────────────────────────────────────────────────────
# Space-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000 http://localhost:5173

# ── Auth ──────────────────────────────────────────────────────────────────────
AUTH_USER=admin
AUTH_PASSWORD=changeme                    # CHANGE THIS in production
JWT_SECRET=change-this-secret            # CHANGE THIS — use a long random string
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

# ── Storage ───────────────────────────────────────────────────────────────────
# Local dev: leave as "data" (creates backend/data/)
# Render:    set to /var/data (persistent disk mount path)
DATA_DIR=data

# ── GA4 single-account bootstrap ──────────────────────────────────────────────
# If accounts.json doesn't exist in DATA_DIR, these values auto-create it.
# On Render: upload your service account JSON via Secret Files -> /etc/secrets/ga4-creds.json
GA4_PROPERTY_ID=            # your numeric GA4 property ID, e.g. 123456789
GA4_ACCOUNT_NAME=Forum      # display name shown in the dashboard
GA4_CREDENTIALS_PATH=keys/ga4-credentials.json   # local dev path
